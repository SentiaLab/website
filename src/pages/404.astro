---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 | SentiaLab">
  <section class="min-h-[80vh] flex items-center justify-center pt-16">
    <div class="text-center px-4">
      <div class="mb-8">
        <span class="text-8xl sm:text-9xl font-bold text-gradient">404</span>
      </div>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-100 mb-4">
        Signal Lost
      </h1>
      <p class="text-lg text-lavender/60 max-w-md mx-auto mb-10 leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
        Let's get you back on track.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center px-8 py-3.5 rounded-xl bg-teal text-charcoal-dark font-semibold text-sm tracking-wide hover:bg-teal-light transition-all duration-300 hover:shadow-lg hover:shadow-teal/20 hover:-translate-y-0.5"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Back to Home
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center justify-center px-8 py-3.5 rounded-xl border border-lavender/30 text-gray-300 font-medium text-sm tracking-wide hover:border-teal/50 hover:text-teal hover:bg-navy/20 transition-all duration-300"
        >
          Contact Us
        </a>
      </div>

      <!-- Decorative elements -->
      <div class="mt-16 flex justify-center gap-2 opacity-20">
        <div class="w-2 h-2 rounded-full bg-teal animate-pulse"></div>
        <div class="w-2 h-2 rounded-full bg-lavender animate-pulse" style="animation-delay: 0.5s;"></div>
        <div class="w-2 h-2 rounded-full bg-gold animate-pulse" style="animation-delay: 1s;"></div>
      </div>
    </div>
  </section>
</Layout>
